# =============================================================================
# Library Management System — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust for your deployment.
#
# Docker Compose (local dev): `docker compose up` auto-reads .env from this dir.
# Coolify (production):       Upload this file or set each var in the UI.
#
# Backend env vars are resolved in:
#   backend/src/main/resources/application.properties  (${VAR:default})
#
# Frontend build-time vars are resolved in:
#   frontend/Dockerfile                                 (ARG VITE_API_BASE_URL)
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# For Docker Compose, use the service name "mysql".
# For Coolify, replace with the Coolify-generated MySQL hostname.
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/library_db?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=password

# MySQL root credentials (used by the mysql service itself)
MYSQL_ROOT_PASSWORD=password
MYSQL_PASSWORD=library_pass

# ── JPA ────────────────────────────────────────────────────────────────────────
# 'update' (default): Hibernate creates/updates tables at startup (needs DB).
# 'none':             App starts without DB access; tables must exist already.
DDL_AUTO=update

# ── JWT ───────────────────────────────────────────────────────────────────────
# In production, generate a random 256-bit key.
#   Linux/macOS:  openssl rand -base64 32
JWT_SECRET=ChamLibrarySecretKeyChangeMeInProduction1234567890

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Frontend (build-time) ────────────────────────────────────────────────────
# Relative path: requests go same-origin → Coolify Caddy proxy → backend.
# Absolute URL:  requests go directly to backend (CORS must be configured).
VITE_API_BASE_URL=/api
