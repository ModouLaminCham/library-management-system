# Copy this file to .env and fill in real values before deploying anywhere
# other than your own laptop. docker-compose.yml reads these automatically.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=password
MYSQL_PASSWORD=library_pass

# --- Backend (Spring Boot) ---
# Used to sign JWTs. Change this to a long, random value in production —
# anyone who knows this secret can forge valid login tokens, including admin ones.
JWT_SECRET=ChamLibrarySecretKeyChangeMeInProduction1234567890

# Comma-separated list of origins allowed to call the API (CORS).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Seeded admin account credentials (only created once, on first run with an
# empty users table). Change these before deploying publicly.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Frontend (React/Vite) ---
# The URL the browser will use to reach the backend API. Must be reachable
# from wherever your users' browsers are, NOT just from inside Docker's
# network — e.g. https://api.yourdomain.com/api in a real deployment.
# This is baked into the static build at build time (Vite inlines env vars),
# so changing it requires rebuilding the frontend image.
VITE_API_BASE_URL=http://localhost:8080/api
